{
  "name": "uniportal",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "shell",
    "design-system",
    "back",
    "academico/front",
    "matricula/front",
    "biblioteca/front",
    "financeiro/front"
  ],
  "scripts": {
    "build:remotes": "npm run build --workspace=mfe-academico && npm run build --workspace=mfe-matricula && npm run build --workspace=mfe-biblioteca && npm run build --workspace=mfe-financeiro",
    "setup:db": "npm run setup --workspace=@uniportal/back",
    "start": "node infra/start.js",
    "install:all": "npm install",
    "lint": "eslint shell/src academico/front/src matricula/front/src design-system/src",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css}\" --ignore-path .gitignore",
    "test": "npm run test --workspace=shell"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.61.0"
  }
}
